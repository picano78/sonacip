## ─────────────────────────────────────────────
##  SONACIP – Variabili d'ambiente per il VPS
##  Copia questo file in .env e compila i valori
## ─────────────────────────────────────────────

## Ambiente: "production" oppure "development"
APP_ENV=production

## Chiave segreta per sessioni e CSRF (OBBLIGATORIA per produzione)
## Genera una chiave sicura con: python3 -c "import secrets; print(secrets.token_hex(32))"
## IMPORTANTE: NON lasciare vuota in produzione!
SECRET_KEY=CHANGEME_GENERATE_WITH_PYTHON_SECRETS

## ── DATABASE ──────────────────────────────────
## PostgreSQL (consigliato per produzione)
## Se omesso o vuoto, l'app usa SQLite automaticamente (file sonacip.db)
DATABASE_URL=postgresql://user:password@localhost:5432/sonacip

## ── EMAIL (SMTP) ──────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@sonacip.it

## ── SUPER ADMIN (primo avvio) ─────────────────
## ⚠️⚠️⚠️ CRITICAL SECURITY NOTICE ⚠️⚠️⚠️
## 
## QUESTI VALORI SONO OBBLIGATORI E DEVONO ESSERE CONFIGURATI!
## Le credenziali hardcoded sono state rimosse per sicurezza.
## 
## PER SVILUPPO LOCALE:
## Sostituisci i placeholder con valori di tua scelta per testing locale.
## Esempio per sviluppo:
##   SUPERADMIN_EMAIL=admin@localhost
##   SUPERADMIN_PASSWORD=DevPassword123!
## 
## PER PRODUZIONE (OBBLIGATORIO):
## 1. Genera credenziali sicure UNICHE per il tuo deployment
## 2. Usa un'email reale che controlli
## 3. Usa una password forte (min 12 caratteri, lettere maiuscole/minuscole, numeri, simboli)
## 4. Cambia la password immediatamente dopo il primo accesso
## 5. NON committare mai il file .env nel repository
##
## NOTA: Se non vengono impostate, l'applicazione genererà credenziali casuali
## e le mostrerà nei log all'avvio (solo in sviluppo). In produzione, l'app
## non si avvierà senza queste variabili impostate.
##
SUPERADMIN_EMAIL=your-email@domain.com
SUPERADMIN_PASSWORD=your-secure-password-here

## ── STRIPE (pagamenti) ───────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PORTAL_RETURN_URL=https://tuodominio.it/subscription/portal-return

## ── DOMINIO ──────────────────────────────────
## Il dominio pubblico dell'applicazione (senza barra finale e senza https://)
## Esempi: sonacip.it, app.miosito.com
APP_DOMAIN=sonacip.it

## ── PROXY (dietro Nginx/Caddy) ───────────────
USE_PROXYFIX=true
SESSION_COOKIE_SECURE=true

## ── CSRF TIMEOUT (opzionale) ─────────────────
## CSRF token timeout in secondi. Default: None (nessuna scadenza)
## Impostato a None per prevenire errori "Sessione scaduta" quando gli utenti
## mantengono aperta la pagina di login per periodi prolungati.
## La sicurezza è garantita dal timeout della sessione (30 giorni).
## Impostare un valore numerico (es. 3600) se si desidera una scadenza specifica.
# WTF_CSRF_TIME_LIMIT=

## ── PERCORSI PERSONALIZZATI (opzionale) ──────
# UPLOAD_FOLDER=/opt/sonacip/uploads
# BACKUP_FOLDER=/opt/sonacip/backups
# LOGS_FOLDER=/opt/sonacip/logs

## ── REDIS (opzionale, per rate limiting) ──────
# REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

## ── CELERY (Background Tasks) ────────────────
## Redis is recommended for Celery broker and backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

## ── SMS (Twilio Integration) ─────────────────
## Sign up at https://www.twilio.com/ to get credentials
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567

## ── STORAGE ──────────────────────────────────
STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=/opt/sonacip/uploads

## ── MEDIA (opzionale) ────────────────────────
MEDIA_MAX_IMAGE_MB=8
MEDIA_MAX_VIDEO_MB=64

## ── SICUREZZA ─────────────────────────────────
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=true
CSP_ENABLED=true
