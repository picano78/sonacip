# Flask Configuration
APP_ENV=production
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-generate-a-strong-one

# Database
# - Leave unset to use the default SQLite database at `./sonacip.db`
# - Or set a real production database URL (recommended)
# DATABASE_URL=postgresql://user:password@localhost/sonacip

# Email Configuration (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@sonacip.it

# SMS Configuration (optional - for future integration)
# SMS_PROVIDER=twilio
# SMS_API_KEY=your-api-key
# SMS_API_SECRET=your-api-secret
# SMS_FROM_NUMBER=+1234567890

# Application URL (for email links)
APP_URL=https://yourdomain.com

# Optional cache/rate limit storage (Redis recommended in production)
REDIS_URL=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=redis://localhost:6379/1

# Reverse proxy support (nginx)
USE_PROXYFIX=true

# Cookies (HTTPS recommended in production)
SESSION_COOKIE_SECURE=true

# Backups (systemd timer)
BACKUP_DIR=/opt/sonacip/backups/system
BACKUP_RETENTION_DAYS=30

# Bootstrap (set once, then rotate in admin)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-after-first-login

# Stripe (billing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PORTAL_RETURN_URL=https://yourdomain.com/subscription/my-subscription

# Storage (optional)
STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=/opt/sonacip/uploads

# Media governance (optional)
MEDIA_MAX_IMAGE_MB=8
MEDIA_MAX_VIDEO_MB=64
MEDIA_VIDEO_MAX_BITRATE=1200000
MEDIA_VIDEO_MAX_WIDTH=1280
