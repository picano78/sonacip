## ─────────────────────────────────────────────
##  SONACIP – Variabili d'ambiente per il VPS
##  Copia questo file in .env e compila i valori
## ─────────────────────────────────────────────

## Ambiente: "production" oppure "development"
APP_ENV=production

## Chiave segreta per sessioni e CSRF (generane una lunga e casuale)
## python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

## ── DATABASE ──────────────────────────────────
## PostgreSQL (consigliato per produzione)
DATABASE_URL=postgresql://user:password@localhost:5432/sonacip

## ── EMAIL (SMTP) ──────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@sonacip.it

## ── SUPER ADMIN (primo avvio) ─────────────────
SUPERADMIN_EMAIL=admin@sonacip.it
SUPERADMIN_PASSWORD=

## ── STRIPE (pagamenti) ───────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PORTAL_RETURN_URL=https://tuodominio.it/subscription/portal-return

## ── DOMINIO ──────────────────────────────────
## Il dominio pubblico dell'applicazione (es. sonacip.it, app.miosito.com)
APP_DOMAIN=sonacip.it

## ── PROXY (dietro Nginx/Caddy) ───────────────
USE_PROXYFIX=true
SESSION_COOKIE_SECURE=true

## ── PERCORSI PERSONALIZZATI (opzionale) ──────
# UPLOAD_FOLDER=/var/www/sonacip/uploads
# BACKUP_FOLDER=/var/www/sonacip/backups
# LOGS_FOLDER=/var/www/sonacip/logs

## ── REDIS (opzionale, per rate limiting) ──────
# REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

## ── STORAGE ──────────────────────────────────
STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=/var/www/sonacip/uploads

## ── MEDIA (opzionale) ────────────────────────
MEDIA_MAX_IMAGE_MB=8
MEDIA_MAX_VIDEO_MB=64

## ── SICUREZZA ─────────────────────────────────
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
