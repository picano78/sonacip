## ─────────────────────────────────────────────
##  SONACIP – Variabili d'ambiente per il VPS
##  Copia questo file in .env e compila i valori
## ─────────────────────────────────────────────

## Ambiente: "production" oppure "development"
APP_ENV=production

## Chiave segreta per sessioni e CSRF (OBBLIGATORIA per produzione)
## Genera una chiave sicura con: python3 -c "import secrets; print(secrets.token_hex(32))"
## IMPORTANTE: NON lasciare vuota in produzione!
SECRET_KEY=CHANGEME_GENERATE_WITH_PYTHON_SECRETS

## ── DATABASE ──────────────────────────────────
## PostgreSQL (consigliato per produzione)
## Se omesso o vuoto, l'app usa SQLite automaticamente (file sonacip.db)
DATABASE_URL=postgresql://user:password@localhost:5432/sonacip

## ── EMAIL (SMTP) ──────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@sonacip.it

## ── SUPER ADMIN (primo avvio) ─────────────────
## ⚠️ IMPORTANTE: Per produzione, imposta SEMPRE credenziali personalizzate!
## Se non specificate, l'applicazione genererà credenziali casuali al primo avvio
## e le stamperà nei log. Assicurati di copiarle e cambiarle immediatamente.
## RACCOMANDAZIONE: Imposta queste variabili PRIMA del primo avvio:
SUPERADMIN_EMAIL=admin@sonacip.it
SUPERADMIN_PASSWORD=

## ── STRIPE (pagamenti) ───────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PORTAL_RETURN_URL=https://tuodominio.it/subscription/portal-return

## ── DOMINIO ──────────────────────────────────
## Il dominio pubblico dell'applicazione (senza barra finale e senza https://)
## Esempi: sonacip.it, app.miosito.com
APP_DOMAIN=sonacip.it

## ── PROXY (dietro Nginx/Caddy) ───────────────
USE_PROXYFIX=true
SESSION_COOKIE_SECURE=true

## ── PERCORSI PERSONALIZZATI (opzionale) ──────
# UPLOAD_FOLDER=/opt/sonacip/uploads
# BACKUP_FOLDER=/opt/sonacip/backups
# LOGS_FOLDER=/opt/sonacip/logs

## ── REDIS (opzionale, per rate limiting) ──────
# REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

## ── STORAGE ──────────────────────────────────
STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=/opt/sonacip/uploads

## ── MEDIA (opzionale) ────────────────────────
MEDIA_MAX_IMAGE_MB=8
MEDIA_MAX_VIDEO_MB=64

## ── SICUREZZA ─────────────────────────────────
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=63072000
HSTS_INCLUDE_SUBDOMAINS=true
CSP_ENABLED=true
